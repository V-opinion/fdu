  <img class="xr_rn_ xr_rnsp_ xr_ap xr_rno_http://localhost:8000/virt033a2dd1/fns%20rollspel_htm_files/384.png " src="30-ars-regeln_files/384@2x.png" alt="political practices in exile" title="" onmousemove="xr_mo(this,0,event)" style="left:0px;top:44px;width:241px;height:41px;">
  <img class="xr_rn_ xr_rnsp_ xr_ap xr_ro xr_ro0 xr_tt3 xr_rno_http://localhost:8000/virt033a2dd1/fns%20rollspel_htm_files/398.png " src="30-ars-regeln_files/398@2x.png" alt="political practices in exile" title="" onmousemove="xr_mo(this,0)" style="left:0px;top:44px;width:241px;height:41px;">
 </a>
 </div>
 <div class="xr_ar xr_nb0">
